{
  "name": "@fboes/aerofly-data",
  "version": "1.5.3",
  "description": "This project contains data sets for airports and aircraft present in Aerofly FS 4.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\"",
    "fetch-csv": "curl -o tmp/airports.csv https://davidmegginson.github.io/ourairports-data/airports.csv",
    "eslint": "npx eslint **/*.js --fix",
    "prettier": "npx prettier --cache --write .",
    "serve": "npx http-server -p 8080 -c-1 . -o dist/index.html"
  },
  "type": "module",
  "author": "Frank Boës <info@3960.org> (https://3960.org/)",
  "license": "MIT",
  "exports": {
    "./data/aircraft-liveries.json": {
      "default": "./data/aircraft-liveries.json",
      "types": "./data/aircraft-liveries.json.d.ts"
    },
    "./data/aircraft.json": {
      "default": "./data/aircraft.json",
      "types": "./data/aircraft.json.d.ts"
    },
    "./data/airport-coordinates.json": {
      "default": "./data/airport-coordinates.json",
      "types": "./data/airport-coordinates.json.d.ts"
    },
    "./data/airport-coordinates-object.json": {
      "default": "./data/airport-coordinates-object.json",
      "types": "./data/airport-coordinates-object.json.d.ts"
    },
    "./data/airport-list.json": {
      "default": "./data/airport-list.json",
      "types": "./data/airport-list.json.d.ts"
    },
    "./data/airports.json": {
      "default": "./data/airports.json",
      "types": "./data/airports.json.d.ts"
    }
  },
  "dependencies": {
    "@fboes/geojson": "^1.0.0",
    "csv-parse": "^5.5.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^48.2.1",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "3.2.5"
  }
}
